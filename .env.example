# Configuración de Cloudflare R2 para la Galería de Fotos
# Reemplaza con tus credenciales reales en un archivo .env o .env.local

R2_ACCESS_KEY_ID=tu_access_key_id_aqui
R2_SECRET_ACCESS_KEY=tu_secret_access_key_aqui

# Endpoint de Cloudflare R2 sin la barra final (slash)
# Formato: https://<account_id>.r2.cloudflarestorage.com
R2_ENDPOINT=https://tu_account_id_aqui.r2.cloudflarestorage.com

# Nombre del bucket en Cloudflare R2 (por defecto: unbj-photos)
R2_BUCKET_NAME=unbj-photos

# URL pública o dominio personalizado para acceder a las fotos (ej. https://pub-xxx.r2.dev/ o https://photos.unbj.cnbm.mx/)
# Debe terminar con una barra final (slash)
R2_PUBLIC_URL=https://pub-tu_bucket_url_aqui.r2.dev/
