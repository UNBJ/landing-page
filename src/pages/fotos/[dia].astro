---
import photosData from '../../data/photos.json';
import { GalleryGrid } from '../../components/GalleryGrid';

export function getStaticPaths() {
  return [
    { params: { dia: 'lunes' }, props: { title: 'Lunes', date: '22 de Junio', photos: photosData.lunes } },
    { params: { dia: 'martes' }, props: { title: 'Martes', date: '23 de Junio', photos: photosData.martes } },
    { params: { dia: 'miercoles' }, props: { title: 'Miércoles', date: '24 de Junio', photos: photosData.miercoles } },
    { params: { dia: 'jueves' }, props: { title: 'Jueves', date: '25 de Junio', photos: photosData.jueves } },
  ];
}

const { dia } = Astro.params;
const { title, date, photos } = Astro.props;

// Traducir dia a formato legible
const displayDay = title;
const totalPhotos = photos.length;
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Destellos del {displayDay} — CONAJEBA 2026 Como el Alba</title>
    <meta name="description" content={`Revive los momentos del día ${displayDay} del congreso CONAJEBA 2026 Como el Alba.`} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={`https://unbj.cnbm.mx/fotos/${dia}`} />
    
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Playfair+Display:ital,wght@0,400;0,600;1,400&display=swap"
      rel="stylesheet"
    />
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      :root {
        --bg-cream: #E9E7E1;
        --bg-dark: #1C1C1C;
        --text-dark: #1C1C1C;
        --text-light: #E8E6DF;
        --text-secondary: #5E5954;
        --accent-red: #D85446;
        --border-soft: rgba(28, 28, 28, 0.15);
      }

      body {
        background: var(--bg-cream);
        color: var(--text-dark);
        font-family: 'Inter', sans-serif;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
      }

      .page-container {
        max-width: 1400px;
        width: 100%;
        margin: 0 auto;
        padding: 0 60px;
        flex: 1;
        display: flex;
        flex-direction: column;
      }

      /* ── Header ─────────────────────────────────── */
      .top-nav {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 32px 0;
        border-bottom: 1px solid var(--border-soft);
      }

      .back-link {
        display: flex;
        align-items: center;
        gap: 8px;
        color: var(--text-dark);
        text-decoration: none;
        font-size: 13px;
        font-weight: 400;
        transition: transform 0.2s, opacity 0.2s;
        opacity: 0.8;
      }

      .back-link:hover {
        opacity: 1;
        transform: translateX(-4px);
      }

      .back-label-full { display: inline; }
      .back-label-short { display: none; }

      .logo-link {
        display: block;
        width: 44px;
        height: 46px;
        flex-shrink: 0;
        transition: transform 0.2s, opacity 0.2s;
      }

      .logo-link:hover {
        transform: scale(1.05);
        opacity: 0.9;
      }

      .logo-link svg {
        width: 100%;
        height: 100%;
      }

      /* ── Title Section ──────────────────────────── */
      .title-section {
        padding: 60px 0 16px;
        display: flex;
        flex-direction: column;
        gap: 20px;
        border-bottom: 1px solid var(--border-soft);
      }

      .main-title {
        font-family: 'Playfair Display', Georgia, serif;
        font-size: 72px;
        font-weight: 400;
        font-style: italic;
        line-height: 1.0;
        color: var(--text-dark);
      }

      .title-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 24px;
      }

      .subtitle {
        font-size: 13px;
        color: var(--text-secondary);
        font-weight: 500;
      }

      .photo-count {
        font-size: 13px;
        font-weight: 500;
        color: var(--text-secondary);
        white-space: nowrap;
      }

      .photo-meta {
        display: none;
      }

      /* ── Grid Section ───────────────────────────── */
      .grid-section {
        padding-top: 64px;
      }

      /* ── Footer ─────────────────────────────────── */
      .footer {
        padding: 48px 0 40px;
        margin-top: auto;
        text-align: center;
        border-top: 1px solid var(--border-soft);
        font-size: 12px;
        color: var(--text-secondary);
        display: flex;
        justify-content: space-between;
        align-items: center;
      }

      .footer-links {
        display: flex;
        gap: 20px;
      }

      .footer-link {
        color: var(--text-secondary);
        text-decoration: none;
        transition: color 0.2s;
      }

      .footer-link:hover {
        color: var(--text-dark);
      }

      /* ── Responsive ─────────────────────────────── */
      @media (max-width: 1024px) {
        .page-container {
          padding: 0 40px;
        }
        .main-title {
          font-size: 56px;
        }
        .grid-section {
          padding-top: 0;
        }
      }

      @media (max-width: 768px) {
        .title-row {
          align-items: flex-start;
          flex-direction: column;
          gap: 8px;
        }
        .photo-count {
          padding-bottom: 0;
        }
      }

      @media (max-width: 640px) {
        .page-container {
          padding: 0 20px;
        }
        .top-nav {
          padding: 18px 0;
        }
        .back-label-full { display: none; }
        .back-label-short { display: inline; }
        .title-section {
          padding: 40px 0 0;
          gap: 10px;
        }
        .eyebrow {
          font-size: 10px;
          letter-spacing: 2.5px;
        }
        .main-title {
          font-size: 42px;
          line-height: 1.05;
        }
        .subtitle {
          font-size: 12px;
        }
        .photo-count {
          display: none;
        }
        .photo-meta {
          display: flex;
          align-items: center;
          gap: 6px;
          padding-top: 6px;
          color: var(--text-secondary);
        }
        .photo-meta-count {
          font-size: 12px;
          font-weight: 500;
          color: var(--text-dark);
        }
        .footer {
          flex-direction: column;
          gap: 16px;
          padding: 40px 0;
        }
      }
    </style>
  </head>
  <body>
    <div class="page-container">
      {/* Barra de navegación */}
      <nav class="top-nav">
        <a href="/#galeria" class="back-link">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="19" y1="12" x2="5" y2="12"></line>
            <polyline points="12 19 5 12 12 5"></polyline>
          </svg>
          <span class="back-label-full">Volver a la página principal</span>
          <span class="back-label-short">Volver</span>
        </a>
        <a href="/" class="logo-link" aria-label="UNBJ">
