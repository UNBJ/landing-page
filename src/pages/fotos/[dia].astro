      {/* Encabezado de la Galería */}
      <header class="title-section">
        <h1 class="main-title">Destellos del {displayDay}</h1>
        <div class="title-row">
          <p class="subtitle">{displayDay} {date} · CONAJEBA 2026 Como el Alba</p>
          <div class="photo-count">{totalPhotos} fotos</div>
        </div>
        <div class="photo-meta">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/>
          </svg>
          <span class="photo-meta-count">{totalPhotos} fotos</span>
        </div>
      </header>

      {/* Grid de Fotos interactivo en React */}
      <main class="grid-section">
        <GalleryGrid photos={photos} client:load />
      </main>

      {/* Pie de página */}
      <footer class="footer">
