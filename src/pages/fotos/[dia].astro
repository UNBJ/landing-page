---
import photosData from '../../data/photos.json';
import { GalleryGrid } from '../../components/GalleryGrid';

export function getStaticPaths() {
  return [
    { params: { dia: 'lunes' }, props: { title: 'Lunes', date: '22 de Junio', photos: photosData.lunes } },
    { params: { dia: 'martes' }, props: { title: 'Martes', date: '23 de Junio', photos: photosData.martes } },
    { params: { dia: 'miercoles' }, props: { title: 'Miércoles', date: '24 de Junio', photos: photosData.miercoles } },
    { params: { dia: 'jueves' }, props: { title: 'Jueves', date: '25 de Junio', photos: photosData.jueves } },
  ];
}

const { dia } = Astro.params;
const { title, date, photos } = Astro.props;

// Traducir dia a formato legible
const displayDay = title;
const totalPhotos = photos.length;
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Fotos del {displayDay} — UNBJ — Un Latir por el Reino</title>
    <meta name="description" content={`Revive los momentos del día ${displayDay} del congreso UNBJ — Un Latir por el Reino.`} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={`https://unbj.cnbm.mx/fotos/${dia}`} />
    
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Playfair+Display:ital,wght@0,400;0,600;1,400&display=swap"
      rel="stylesheet"
    />
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      :root {
        --bg-cream: #E9E7E1;
        --bg-dark: #1C1C1C;
        --text-dark: #1C1C1C;
        --text-light: #E8E6DF;
        --text-secondary: #5E5954;
        --accent-red: #D85446;
        --border-soft: rgba(28, 28, 28, 0.15);
      }

      body {
        background: var(--bg-cream);
        color: var(--text-dark);
        font-family: 'Inter', sans-serif;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
      }

      .page-container {
        max-width: 1400px;
        width: 100%;
        margin: 0 auto;
        padding: 0 60px;
        flex: 1;
        display: flex;
        flex-direction: column;
      }

      /* ── Header ─────────────────────────────────── */
      .top-nav {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 32px 0;
        border-bottom: 1px solid var(--border-soft);
      }

      .back-link {
        display: flex;
        align-items: center;
        gap: 8px;
        color: var(--text-dark);
        text-decoration: none;
        font-size: 13px;
        font-weight: 500;
        letter-spacing: 0.5px;
        transition: transform 0.2s, opacity 0.2s;
        opacity: 0.8;
      }

      .back-link:hover {
        opacity: 1;
        transform: translateX(-4px);
      }

      .wordmark {
        font-family: 'Playfair Display', Georgia, serif;
        font-style: italic;
        font-weight: 600;
        font-size: 18px;
        color: var(--text-dark);
        text-decoration: none;
      }

      /* ── Title Section ──────────────────────────── */
      .title-section {
        padding: 56px 0 40px;
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
        gap: 32px;
      }

      .title-left {
        max-width: 600px;
      }

      .eyebrow {
        font-size: 11px;
        font-weight: 600;
        color: var(--text-secondary);
        letter-spacing: 2px;
        text-transform: uppercase;
        margin-bottom: 12px;
      }

      .main-title {
        font-family: 'Playfair Display', Georgia, serif;
        font-size: 48px;
        font-weight: 400;
        font-style: italic;
        line-height: 1.1;
        margin-bottom: 8px;
      }

      .subtitle {
        font-size: 14px;
        color: var(--text-secondary);
        line-height: 1.5;
      }

      .photo-count {
        font-size: 13px;
        font-weight: 500;
        color: var(--text-secondary);
        padding-bottom: 8px;
      }

      /* ── Footer ─────────────────────────────────── */
      .footer {
        padding: 60px 0 40px;
        margin-top: auto;
        text-align: center;
        border-top: 1px solid var(--border-soft);
        font-size: 12px;
        color: var(--text-secondary);
        display: flex;
        justify-content: space-between;
        align-items: center;
      }

      .footer-links {
        display: flex;
        gap: 20px;
      }

      .footer-link {
        color: var(--text-secondary);
        text-decoration: none;
        transition: color 0.2s;
      }

      .footer-link:hover {
        color: var(--text-dark);
      }

      /* ── Responsive ─────────────────────────────── */
      @media (max-width: 1024px) {
        .page-container {
          padding: 0 40px;
        }
        .main-title {
          font-size: 40px;
        }
      }

      @media (max-width: 768px) {
        .title-section {
          flex-direction: column;
          align-items: flex-start;
          gap: 16px;
          padding: 40px 0 28px;
        }
        .photo-count {
          padding-bottom: 0;
        }
      }

      @media (max-width: 640px) {
        .page-container {
          padding: 0 20px;
        }
        .top-nav {
          padding: 24px 0;
        }
        .main-title {
          font-size: 32px;
        }
        .footer {
          flex-direction: column;
          gap: 16px;
          padding: 40px 0;
        }
      }
    </style>
  </head>
  <body>
    <div class="page-container">
      {/* Barra de navegación */}
      <nav class="top-nav">
        <a href="/#galeria" class="back-link">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2.5" strokeLinecap="round" strokeLinejoin="round">
            <line x1="19" y1="12" x2="5" y2="12"></line>
            <polyline points="12 19 5 12 12 5"></polyline>
          </svg>
          Volver
        </a>
        <a href="/" class="wordmark">UNBJ</a>
      </nav>

      {/* Encabezado de la Galería */}
      <header class="title-section">
        <div class="title-left">
          <div class="eyebrow">Galería de Fotos</div>
          <h1 class="main-title">Fotos del {displayDay}</h1>
          <p class="subtitle">Revive los momentos más significativos de este {displayDay.toLowerCase()}, {date}.</p>
        </div>
        <div class="photo-count">
          <span>{totalPhotos} fotos en total</span>
        </div>
      </header>

      {/* Grid de Fotos interactivo en React */}
      <main>
        <GalleryGrid photos={photos} client:load />
      </main>

      {/* Pie de página */}
      <footer class="footer">
        <p>&copy; {new Date().getFullYear()} UNBJ — Un Latir por el Reino.</p>
        <div class="footer-links">
          <a href="/" class="footer-link">Inicio</a>
          <a href="/#galeria" class="footer-link">Galería</a>
        </div>
      </footer>
    </div>
  </body>
</html>
