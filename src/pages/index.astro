          {/* Jueves */}
          <div class="collage-pane" id="pane-jueves">
            <div class="collage-col collage-col--side-left">
              <div class="collage-img-wrapper h-vertical-top">
                <img src={photosData.jueves[0]?.url} alt="Foto Jueves 1" class="collage-img" loading="lazy" />
              </div>
              <div class="collage-img-wrapper h-landscape-bottom">
                <img src={photosData.jueves[3]?.url} alt="Foto Jueves 4" class="collage-img" loading="lazy" />
