      </section>

      <!-- ── Sección Calendario ── -->
      <section class="calendario" id="calendario">
        <div class="calendario__inner">
          <header class="cal-encabezado">
            <span class="cal-caption" id="cal-caption">PROGRAMA · DÍA 01</span>
            <h2 class="cal-titulo">Calendario de Actividades</h2>
            <p class="cal-subtitulo">CONAJEBA 2026 Como el Alba — Satélite, CDMX.</p>
          </header>

          <div class="cal-selector" role="tablist" aria-label="Días del congreso">
            {diasCalendario.map((dia, i) => (
              <button
                class:list={['cal-dia', { active: i === 0 }]}
                data-day={dia.slug}
                role="tab"
                aria-selected={i === 0 ? 'true' : 'false'}
                aria-controls={`cal-pane-${dia.slug}`}
              >
                <span class="cal-dia__num">{dia.num}</span>
                <span class="cal-dia__nombre">{dia.nombre}</span>
                <span class="cal-dia__dot" aria-hidden="true"></span>
              </button>
            ))}
          </div>

          <div class="cal-main">
            <div class="cal-meta">
              <span class="cal-meta__dia" id="cal-meta-dia">LUNES — DÍA 01</span>
              <span class="cal-meta__conteo" id="cal-meta-conteo">{calendarioInfo.lunes.conteo}</span>
            </div>

            {diasCalendario.map((dia, i) => (
              <div class:list={['cal-pane', { active: i === 0 }]} id={`cal-pane-${dia.slug}`} role="tabpanel">
                {scheduleData[dia.slug].length === 0 ? (
                  <p class="cal-vacio">Programa por anunciar.</p>
                ) : (
                  scheduleData[dia.slug].map((evento) => {
                    const rango = rangoMinutos(evento.horario);
                    return (
                      <article
                        class:list={[
                          'cal-evento',
                          {
                            'cal-evento--destacado': evento.tipo === 'destacado',
                            'cal-evento--principal': evento.tipo === 'principal',
                          },
                        ]}
                        data-inicio={rango.inicio}
                        data-fin={rango.fin}
                      >
                        <div class="cal-evento__horario">
                          <span class="cal-evento__hora">{evento.horario}</span>
                          <span class="cal-evento__dur-corta">{evento.duracion}</span>
                        </div>
                        <div class="cal-evento__contenido">
                          <div class="cal-evento__tags">
                            {evento.tipo === 'principal' && <span class="cal-evento__tag">EVENTO PRINCIPAL</span>}
                            <span class="cal-evento__envivo">
                              <span class="cal-evento__pulso" aria-hidden="true"></span>EN CURSO
                            </span>
                          </div>
                          <p class="cal-evento__actividad">{evento.actividad}</p>
                          <span class="cal-evento__duracion">Duración — {evento.duracion}</span>
                        </div>
                      </article>
                    );
                  })
                )}
              </div>
            ))}
          </div>

          <p class="cal-nota">El programa puede ajustarse durante el congreso.</p>
        </div>
      </section>

      <!-- ── Sección Croquis ── -->
      <section class="croquis" id="croquis" aria-labelledby="croquis-title">
        <div class="croquis__inner">
          <div class="croquis__rail">
            <header class="croquis__header">
              <span class="croquis__caption">UBICACIÓN · CAMPUS</span>
              <h2 class="croquis__title" id="croquis-title">Croquis del Campus</h2>
              <p class="croquis__subtitle">Satélite Zona Esmeralda, Naucalpan de Juárez, Estado de México.</p>
            </header>

            <div class="croquis__details">
              <span class="croquis__hairline" aria-hidden="true"></span>
              <p class="croquis__info croquis__info--desktop">El campus cuenta con salones de conferencia, cafetería, canchas deportivas, áreas verdes y estacionamiento.</p>
              <p class="croquis__info croquis__info--mobile">El campus cuenta con salones, cafetería, canchas y áreas verdes.</p>
              <span class="croquis__hairline" aria-hidden="true"></span>
            </div>

            <p class="croquis__note">El croquis es una referencia visual. Las áreas pueden variar.</p>
          </div>

          <div class="croquis__map">
            <img src="/croquis-campus.svg" alt="Croquis del campus Satélite Zona Esmeralda" class="croquis__map-img" loading="lazy" />
          </div>
        </div>
      </section>

      <!-- ── Sección Galería ── -->
      <section class="galeria" id="galeria">
        <div class="galeria__header">
          <span class="galeria__eyebrow">GALERÍA</span>
          <h2 class="galeria__title">Destellos del Alba</h2>
          <p class="galeria__subtitle">Revive los momentos más significativos del CONAJEBA 2026, día por día.</p>
        </div>

        <!-- Pestañas -->
        <div class="tabs">
          <button class="tab-btn active" data-day="lunes">Lunes</button>
          <button class="tab-btn" data-day="martes">Martes</button>
          <button class="tab-btn" data-day="miercoles">Miércoles</button>
          <button class="tab-btn" data-day="jueves">Jueves</button>
        </div>

        <!-- Contenedor de Collages -->
        <div class="collages-container">
          {/* Lunes */}
          <div class="collage-pane active" id="pane-lunes">
            <div class="collage-col collage-col--side-left">
              <div class="collage-img-wrapper h-vertical-top">
                <img src={photosData.lunes[0]?.url} alt="Foto Lunes 1" class="collage-img" loading="lazy" />
              </div>
              <div class="collage-img-wrapper h-landscape-bottom">
                <img src={photosData.lunes[3]?.url} alt="Foto Lunes 4" class="collage-img" loading="lazy" />
              </div>
            </div>
            <div class="collage-col collage-col--hero">
              <div class="collage-img-wrapper h-hero">
                <img src={photosData.lunes[1]?.url} alt="Foto Lunes 2 (Hero)" class="collage-img" loading="lazy" />
              </div>
            </div>
            <div class="collage-col collage-col--side-right">
              <div class="collage-img-wrapper h-landscape-top">
                <img src={photosData.lunes[2]?.url} alt="Foto Lunes 3" class="collage-img" loading="lazy" />
              </div>
              <div class="collage-img-wrapper h-vertical-bottom">
                <img src={photosData.lunes[4]?.url} alt="Foto Lunes 5" class="collage-img" loading="lazy" />
              </div>
            </div>
          </div>

          {/* Martes */}
          <div class="collage-pane" id="pane-martes">
