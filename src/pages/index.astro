                <img src={photosData.martes[3]?.url} alt="Foto Martes 4" class="collage-img" loading="lazy" />
              </div>
            </div>
            <div class="collage-col collage-col--hero">
              <div class="collage-img-wrapper h-hero">
                <img src={photosData.martes[1]?.url} alt="Foto Martes 2 (Hero)" class="collage-img" loading="lazy" />
              </div>
            </div>
            <div class="collage-col collage-col--side-right">
              <div class="collage-img-wrapper h-landscape-top">
                <img src={photosData.martes[2]?.url} alt="Foto Martes 3" class="collage-img" loading="lazy" />
