    <!-- Client-side script to handle tab switching -->
    <script is:inline define:vars={{ photosCount: {
      lunes: photosData.lunes.length,
      martes: photosData.martes.length,
      miercoles: photosData.miercoles.length,
      jueves: photosData.jueves.length
    }}}>
      document.addEventListener('DOMContentLoaded', () => {
        const tabBtns = document.querySelectorAll('.tab-btn');
        const collagePanes = document.querySelectorAll('.collage-pane');
        const ctaLink = document.getElementById('gallery-cta-link');
        const ctaText = document.getElementById('gallery-cta-text');
        const ctaCounter = document.getElementById('gallery-cta-counter');

        if (!ctaLink || !ctaText || !ctaCounter) return;

        tabBtns.forEach(btn => {
          btn.addEventListener('click', () => {
            const day = btn.getAttribute('data-day');
            if (!day) return;

            // Activar botón
            tabBtns.forEach(b => b.classList.remove('active'));
            btn.classList.add('active');

            // Activar pane
            collagePanes.forEach(pane => pane.classList.remove('active'));
            const targetPane = document.getElementById(`pane-${day}`);
            if (targetPane) {
              targetPane.classList.add('active');
            }

            // Actualizar CTA
            const formattedDay = day.charAt(0).toUpperCase() + day.slice(1);
            ctaLink.setAttribute('href', `/fotos/${day}`);
            ctaText.textContent = `Ver todas las fotos del ${formattedDay === 'Miercoles' ? 'Miércoles' : formattedDay}`;
            ctaCounter.textContent = `+${photosCount[day]} fotos`;
          });
        });
      });
    </script>

    <!-- Client-side script para el selector de días y el marcador "EN CURSO" -->
    <script is:inline define:vars={{ calendarioInfo, congresoFechas }}>
      document.addEventListener('DOMContentLoaded', () => {
        const diaBtns = document.querySelectorAll('.cal-dia');
        const panes = document.querySelectorAll('.cal-pane');
        const caption = document.getElementById('cal-caption');
        const metaDia = document.getElementById('cal-meta-dia');
        const metaConteo = document.getElementById('cal-meta-conteo');

        if (!caption || !metaDia || !metaConteo) return;

        diaBtns.forEach(btn => {
          btn.addEventListener('click', () => {
            const day = btn.getAttribute('data-day');
            const info = day ? calendarioInfo[day] : null;
            if (!info) return;

            diaBtns.forEach(b => {
              b.classList.remove('active');
              b.setAttribute('aria-selected', 'false');
            });
            btn.classList.add('active');
            btn.setAttribute('aria-selected', 'true');

            panes.forEach(pane => pane.classList.remove('active'));
            const targetPane = document.getElementById(`cal-pane-${day}`);
            if (targetPane) {
              targetPane.classList.add('active');
            }

            caption.textContent = `PROGRAMA · DÍA ${info.num}`;
            metaDia.textContent = `${info.label} — DÍA ${info.num}`;
            metaConteo.textContent = info.conteo;
          });
        });

        // ── Marcador "EN CURSO" (hora de CDMX) ──
        const ahoraCDMX = () => {
          const parts = new Intl.DateTimeFormat('en-CA', {
            timeZone: 'America/Mexico_City',
            year: 'numeric', month: '2-digit', day: '2-digit',
            hour: '2-digit', minute: '2-digit', hourCycle: 'h23',
          }).formatToParts(new Date());
          const get = (tipo) => parts.find(p => p.type === tipo)?.value ?? '';
          return {
            fecha: `${get('year')}-${get('month')}-${get('day')}`,
            minutos: Number(get('hour')) * 60 + Number(get('minute')),
          };
        };

        const aplicarEnVivo = () => {
          document.querySelectorAll('.cal-evento--vivo').forEach(ev => {
            ev.classList.remove('cal-evento--vivo');
          });

          const { fecha, minutos } = ahoraCDMX();
          const diaHoy = congresoFechas[fecha];
          if (!diaHoy) return;

          document.querySelectorAll(`#cal-pane-${diaHoy} .cal-evento`).forEach(ev => {
            const inicio = Number(ev.dataset.inicio);
            const fin = Number(ev.dataset.fin);
            if (!Number.isNaN(inicio) && !Number.isNaN(fin) && minutos >= inicio && minutos < fin) {
              ev.classList.add('cal-evento--vivo');
            }
          });
        };

        // Durante el congreso, abrir directamente en el día actual
        const diaHoy = congresoFechas[ahoraCDMX().fecha];
        if (diaHoy) {
          const btnHoy = document.querySelector(`.cal-dia[data-day="${diaHoy}"]`);
          if (btnHoy) btnHoy.click();
        }

        aplicarEnVivo();
        setInterval(aplicarEnVivo, 60000);
      });
    </script>
  </body>
</html>
