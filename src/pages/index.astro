---
import photosData from '../data/photos.json';
import scheduleData from '../data/schedule.json';

const diasCalendario = [
  { slug: 'lunes', nombre: 'Lunes', label: 'LUNES', num: '01' },
  { slug: 'martes', nombre: 'Martes', label: 'MARTES', num: '02' },
  { slug: 'miercoles', nombre: 'Miércoles', label: 'MIÉRCOLES', num: '03' },
  { slug: 'jueves', nombre: 'Jueves', label: 'JUEVES', num: '04' },
] as const;

const conteoActividades = (n: number) =>
  n === 0 ? 'PRÓXIMAMENTE' : n === 1 ? '1 ACTIVIDAD' : `${n} ACTIVIDADES`;

const calendarioInfo = Object.fromEntries(
  diasCalendario.map((dia) => [
    dia.slug,
    { label: dia.label, num: dia.num, conteo: conteoActividades(scheduleData[dia.slug].length) },
  ])
);

// Fechas reales del congreso (hora de CDMX) para el marcador "EN CURSO"
const congresoFechas = {
  '2026-07-27': 'lunes',
  '2026-07-28': 'martes',
  '2026-07-29': 'miercoles',
  '2026-07-30': 'jueves',
};

const aMinutos = (hhmm: string) => {
  const [h, m] = hhmm.split(':').map(Number);
  return h * 60 + m;
};

const rangoMinutos = (horario: string) => {
  const [inicio, fin] = horario.split(' — ');
  return { inicio: aMinutos(inicio), fin: aMinutos(fin) };
};
---
<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>UNBJ — Un Latir por el Reino</title>
    <meta name="description" content="Que todos sean uno, como tú, Padre, en mí, y yo en ti, para que el mundo crea que tú me enviaste." />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href="https://unbj.cnbm.mx/" />
    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://unbj.cnbm.mx/" />
    <meta property="og:title" content="UNBJ — Un Latir por el Reino" />
    <meta property="og:description" content="Que todos sean uno, como tú, Padre, en mí, y yo en ti, para que el mundo crea que tú me enviaste." />
    <meta property="og:locale" content="es_MX" />
    <!-- Twitter/X -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content="UNBJ — Un Latir por el Reino" />
    <meta name="twitter:description" content="Que todos sean uno, como tú, Padre, en mí, y yo en ti, para que el mundo crea que tú me enviaste." />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Playfair+Display:ital,wght@0,400;0,700;1,400&display=swap"
      rel="stylesheet"
    />
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      :root {
        --bg-cream: #E9E7E1;
        --bg-dark: #1C1C1C;
        --text-dark: #1C1C1C;
        --text-light: #E8E6DF;
        --text-secondary: #5E5954;
        --accent-red: #D85446;
      }

      html, body { height: 100%; }

      body {
        background: var(--bg-cream);
        color: var(--text-dark);
        font-family: 'Inter', sans-serif;
      }

      .page {
        display: flex;
        flex-direction: column;
        min-height: 100vh;
      }

      /* ── Header ─────────────────────────────────── */
      .header {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        padding: 32px 60px 0;
        gap: 24px;
        min-height: 158px;
      }

      .quote__text {
        font-family: 'Playfair Display', Georgia, serif;
        font-style: italic;
        font-weight: 400;
        font-size: 13px;
        line-height: 1.5;
        color: var(--text-dark);
        max-width: 340px;
      }

      .quote__ref {
        margin-top: 28px;
        font-family: 'Inter', sans-serif;
        font-weight: 500;
        font-size: 11px;
        letter-spacing: 2px;
        color: var(--text-secondary);
      }

      .nav-logo {
        flex-shrink: 0;
        width: 86px;
        height: 90px;
      }

      .nav-logo svg { width: 100%; height: 100%; }

      .divider {
        border: none;
        border-top: 1px solid rgba(28, 28, 28, 0.15);
      }

      /* ── Hero ───────────────────────────────────── */
      .hero {
        flex: 1;
        position: relative;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 0 80px 40px;
        overflow: hidden;
      }

      .hero__decor {
        position: absolute;
        pointer-events: none;
        user-select: none;
      }

      .hero__decor--cross {
        right: -1%;
        top: 8%;
        width: clamp(140px, 19vw, 280px);
        height: auto;
        opacity: 0.035;
      }

      .hero__decor--arc {
        right: -4%;
        bottom: 3%;
        width: clamp(70px, 10vw, 140px);
        height: auto;
        opacity: 0.12;
      }

      .hero__main {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 28px;
        width: 100%;
        max-width: 860px;
        position: relative;
        z-index: 1;
      }

      .label-logo { width: 100%; }
      .label-logo svg { width: 100%; height: auto; display: block; }

      .accent-line {
        width: 60px;
        height: 3px;
        background: var(--accent-red);
        flex-shrink: 0;
      }

      /* ── Tablet ≤ 1024px ────────────────────────── */
      @media (max-width: 1024px) {
        .header {
          padding: 24px 40px 0;
          min-height: 120px;
        }
        .quote__text { font-size: 12px; max-width: 280px; }
        .quote__ref { margin-top: 16px; }
        .nav-logo { width: 64px; height: 67px; }
        .hero { padding: 0 40px 40px; }
        .hero__main { max-width: 620px; }
        .hero__decor--cross { display: none; }
      }

      /* ── Mobile ≤ 640px ─────────────────────────── */
      @media (max-width: 640px) {
        .header {
          padding: 20px 20px 0;
          gap: 12px;
          min-height: 0;
          align-items: center;
        }
        .quote__text { font-size: 11px; max-width: 200px; }
        .quote__ref { margin-top: 10px; font-size: 10px; letter-spacing: 1.5px; }
        .nav-logo { width: 44px; height: 46px; }
        .hero { padding: 40px 20px 32px; align-items: flex-start; }
        .hero__main { gap: 20px; }
        .hero__decor--arc { display: none; }
      }

      /* ── Calendario Sección ────────────────────── */
      .calendario {
        background: var(--bg-cream);
        border-top: 1px solid rgba(28, 28, 28, 0.15);
        padding: 110px 60px 100px;
      }

      .calendario__inner {
        max-width: 1200px;
        margin: 0 auto;
        display: grid;
        grid-template-columns: 380px 1fr;
        grid-template-rows: auto auto 1fr;
        grid-template-areas:
          "encabezado main"
          "selector main"
          "nota main";
        column-gap: 96px;
        row-gap: 56px;
        align-items: start;
      }

      .cal-encabezado {
        grid-area: encabezado;
        display: flex;
        flex-direction: column;
        gap: 20px;
      }

      .cal-caption {
        font-size: 12px;
        font-weight: 600;
        letter-spacing: 3px;
        color: var(--accent-red);
      }

      .cal-titulo {
        font-family: 'Playfair Display', Georgia, serif;
        font-size: 58px;
        font-weight: 700;
        line-height: 1.08;
        color: var(--text-dark);
      }

      .cal-subtitulo {
        font-size: 15px;
        line-height: 1.55;
        color: var(--text-secondary);
      }

      /* Selector de días */
      .cal-selector {
        grid-area: selector;
        display: flex;
        flex-direction: column;
      }

      .cal-dia {
        display: flex;
        align-items: center;
        width: 100%;
        padding: 18px 2px;
        background: none;
        border: none;
        border-top: 1px solid rgba(28, 28, 28, 0.12);
        cursor: pointer;
        text-align: left;
      }

      .cal-dia:last-child {
        border-bottom: 1px solid rgba(28, 28, 28, 0.12);
      }

      .cal-dia__num {
        font-family: 'Inter', sans-serif;
        font-size: 12px;
        font-weight: 600;
        letter-spacing: 1px;
        color: rgba(94, 89, 84, 0.6);
        margin-right: 18px;
        transition: color 0.3s;
      }

      .cal-dia__nombre {
        font-family: 'Playfair Display', Georgia, serif;
        font-size: 24px;
        font-weight: normal;
        color: rgba(94, 89, 84, 0.6);
        transition: color 0.3s;
      }

      .cal-dia__dot {
        width: 7px;
        height: 7px;
        border-radius: 50%;
        background: var(--accent-red);
        margin-left: auto;
        opacity: 0;
        transition: opacity 0.3s;
      }

      .cal-dia:hover .cal-dia__nombre { color: var(--text-dark); }

      .cal-dia.active .cal-dia__num { color: var(--accent-red); }
      .cal-dia.active .cal-dia__nombre { color: var(--text-dark); font-weight: 700; }
      .cal-dia.active .cal-dia__dot { opacity: 1; }

      /* Timeline */
      .cal-main { grid-area: main; }

      .cal-meta {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding-bottom: 16px;
      }

      .cal-meta__dia {
        font-size: 12px;
        font-weight: 600;
        letter-spacing: 2px;
        color: var(--text-dark);
      }

      .cal-meta__conteo {
        font-size: 12px;
        font-weight: 500;
        letter-spacing: 2px;
        color: var(--text-secondary);
      }

      .cal-pane { display: none; }

      .cal-pane.active {
        display: block;
        animation: fadeInCollage 0.5s ease-out;
      }

      .cal-evento { display: flex; }

      .cal-evento__horario {
        flex: 0 0 140px;
        padding: 26px 0;
      }

      .cal-evento__hora {
        font-size: 15px;
        font-weight: 600;
        letter-spacing: 0.5px;
        color: var(--text-dark);
      }

      .cal-evento__dur-corta { display: none; }

      .cal-evento__contenido {
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: 6px;
        padding: 24px 0 24px 38px;
        border-left: 2px solid rgba(28, 28, 28, 0.15);
      }

      .cal-evento__tags {
        display: flex;
        align-items: center;
        gap: 8px;
      }

      /* La fila de tags solo ocupa espacio si hay algo que mostrar */
      .cal-evento:not(.cal-evento--principal):not(.cal-evento--vivo) .cal-evento__tags {
        display: none;
      }

      .cal-evento__tag {
        font-size: 11px;
        font-weight: 600;
        letter-spacing: 2.5px;
        color: var(--accent-red);
      }

      /* Badge "EN CURSO" (visible solo con .cal-evento--vivo) */
      .cal-evento__envivo {
        display: none;
        align-items: center;
        gap: 7px;
        font-size: 11px;
        font-weight: 600;
        letter-spacing: 2.5px;
        color: var(--accent-red);
      }

      .cal-evento--vivo .cal-evento__envivo { display: inline-flex; }

      .cal-evento--principal .cal-evento__envivo::before { content: '·'; }

      .cal-evento__pulso {
        width: 7px;
        height: 7px;
        border-radius: 50%;
        background: var(--accent-red);
        animation: pulsoEnVivo 1.6s ease-in-out infinite;
      }

      @keyframes pulsoEnVivo {
        0%, 100% { opacity: 1; box-shadow: 0 0 0 0 rgba(216, 84, 70, 0.35); }
        50% { opacity: 0.55; box-shadow: 0 0 0 5px rgba(216, 84, 70, 0); }
      }

      .cal-evento--vivo .cal-evento__contenido { border-left-color: var(--accent-red); }

      .cal-evento__actividad {
        font-size: 17px;
        line-height: 1.4;
        color: var(--text-dark);
      }

      .cal-evento__duracion {
        font-size: 12px;
        letter-spacing: 1px;
        color: var(--text-secondary);
      }

      /* Evento destacado (hora crítica, en rojo) */
      .cal-evento--destacado .cal-evento__hora,
      .cal-evento--destacado .cal-evento__actividad {
        color: var(--accent-red);
      }

      .cal-evento--destacado .cal-evento__actividad { font-weight: 600; }

      /* Evento principal */
      .cal-evento--principal .cal-evento__contenido { border-left-color: var(--accent-red); }

      .cal-evento--principal .cal-evento__actividad {
        font-family: 'Playfair Display', Georgia, serif;
        font-size: 28px;
        font-weight: 700;
        line-height: 1.2;
      }

      .cal-vacio {
        padding: 48px 0;
        border-top: 1px solid rgba(28, 28, 28, 0.12);
        font-family: 'Playfair Display', Georgia, serif;
        font-style: italic;
        font-size: 16px;
        color: var(--text-secondary);
      }

      .cal-nota {
        grid-area: nota;
        font-family: 'Playfair Display', Georgia, serif;
        font-style: italic;
        font-size: 14px;
        color: var(--text-secondary);
      }

      /* ── Tablet Calendario ─────────────────────── */
      @media (max-width: 1024px) {
        .calendario { padding: 84px 40px 72px; }
        .calendario__inner {
          grid-template-columns: 1fr;
          grid-template-rows: auto;
          grid-template-areas:
            "encabezado"
            "selector"
            "main"
            "nota";
          row-gap: 44px;
        }
        .cal-encabezado { gap: 16px; }
        .cal-titulo { font-size: 44px; line-height: 1.1; }
        .cal-subtitulo { line-height: 1.5; }

        .cal-selector {
          flex-direction: row;
          gap: 36px;
          padding: 16px 0;
          border-top: 1px solid rgba(28, 28, 28, 0.12);
          border-bottom: 1px solid rgba(28, 28, 28, 0.12);
        }
        .cal-dia { width: auto; padding: 0; border: none; }
        .cal-dia:last-child { border-bottom: none; }
        .cal-dia__num { font-size: 11px; margin-right: 12px; }
        .cal-dia__nombre { font-size: 21px; }
        .cal-dia__dot { display: none; }

        .cal-meta { padding-bottom: 14px; }
        .cal-meta__dia, .cal-meta__conteo { font-size: 11px; }

        .cal-evento__horario { flex: 0 0 118px; padding: 22px 0; }
        .cal-evento__hora { font-size: 13px; }
        .cal-evento__contenido { gap: 5px; padding: 20px 0 20px 30px; }
        .cal-evento__actividad { font-size: 15px; line-height: 1.45; }
        .cal-evento__duracion { font-size: 11px; }
        .cal-evento__tag, .cal-evento__envivo { font-size: 10px; }
        .cal-evento__pulso { width: 6px; height: 6px; }
        .cal-evento--principal .cal-evento__actividad { font-size: 24px; }
        .cal-nota { font-size: 13px; }
      }

      /* ── Mobile Calendario ─────────────────────── */
      @media (max-width: 640px) {
        .calendario { padding: 64px 20px 56px; }
        .calendario__inner { row-gap: 32px; }
        .cal-encabezado { gap: 12px; }
        .cal-caption { font-size: 11px; }
        .cal-titulo { font-size: 32px; line-height: 1.12; }
        .cal-subtitulo { font-size: 14px; }

        .cal-selector { justify-content: space-between; gap: 12px; padding: 12px 0; }
        .cal-dia { gap: 7px; }
        .cal-dia__num { display: none; }
        .cal-dia__nombre { font-size: 16px; }
        .cal-dia__dot { display: block; width: 6px; height: 6px; margin-left: 0; order: -1; }
        .cal-dia:not(.active) .cal-dia__dot { display: none; }

        .cal-meta { padding-bottom: 12px; }
        .cal-meta__dia, .cal-meta__conteo { font-size: 10px; }

        /* El evento completo se vuelve la tarjeta con borde izquierdo */
        .cal-evento {
          flex-direction: column;
          gap: 5px;
          padding: 16px 0 16px 18px;
          border-left: 2px solid rgba(28, 28, 28, 0.15);
        }
        .cal-evento--principal, .cal-evento--vivo { border-left-color: var(--accent-red); }
        .cal-evento__horario {
          flex: none;
          width: 100%;
          padding: 0;
          display: flex;
          align-items: center;
          justify-content: space-between;
        }
        .cal-evento__hora { font-size: 13px; }
        .cal-evento__dur-corta {
          display: inline;
          font-size: 11px;
          letter-spacing: 1px;
          color: var(--text-secondary);
        }
        .cal-evento__contenido { border-left: none; padding: 0; }
        .cal-evento--principal .cal-evento__contenido { border-left: none; }
        .cal-evento__duracion { display: none; }
        .cal-evento__actividad { font-size: 14px; }
        .cal-evento--principal .cal-evento__actividad { font-size: 21px; line-height: 1.25; }
        .cal-vacio { padding: 32px 0; font-size: 14px; }
      }

      /* ── Croquis Sección ───────────────────────── */
      .croquis {
        background: var(--bg-cream);
        border-top: 1px solid rgba(28, 28, 28, 0.15);
        padding: 100px 120px 80px;
      }

      .croquis__inner {
        max-width: 1200px;
        margin: 0 auto;
        display: grid;
        grid-template-columns: 380px 1fr;
        gap: 80px;
        align-items: start;
      }

      .croquis__rail {
        display: flex;
        flex-direction: column;
        gap: 48px;
      }

      .croquis__header {
        display: flex;
        flex-direction: column;
        gap: 20px;
      }

      .croquis__caption {
        font-size: 12px;
        font-weight: 600;
        letter-spacing: 3px;
        color: var(--accent-red);
      }

      .croquis__title {
        font-family: 'Playfair Display', Georgia, serif;
        font-size: 58px;
        font-weight: 700;
        line-height: 1.08;
        color: var(--text-dark);
      }

      .croquis__subtitle {
        font-size: 15px;
        line-height: 1.55;
        color: var(--text-secondary);
      }

      .croquis__details {
        display: flex;
        flex-direction: column;
        gap: 24px;
      }

      .croquis__hairline {
        width: 100%;
        height: 1px;
        background: rgba(28, 28, 28, 0.12);
      }

      .croquis__info {
        font-size: 14px;
        line-height: 1.6;
        color: var(--text-secondary);
      }

      .croquis__info--mobile { display: none; }

      .croquis__note {
        font-family: 'Playfair Display', Georgia, serif;
        font-style: italic;
        font-size: 14px;
        color: var(--text-secondary);
      }

      .croquis__map {
        display: flex;
        justify-content: center;
        width: 100%;
      }

      .croquis__map-img {
        width: 580px;
        max-width: 100%;
        height: auto;
        display: block;
        mix-blend-mode: multiply;
      }

      /* ── Tablet Croquis ────────────────────────── */
      @media (max-width: 1024px) {
        .croquis {
          padding: 84px 64px 72px;
        }

        .croquis__inner {
          grid-template-columns: 1fr;
          gap: 40px;
        }

        .croquis__rail {
          gap: 40px;
        }

        .croquis__header {
          gap: 16px;
        }

        .croquis__title {
          font-size: 44px;
          line-height: 1.1;
        }

        .croquis__subtitle {
          line-height: 1.5;
        }

        .croquis__details {
          gap: 16px;
        }

        .croquis__map-img {
          width: 520px;
        }

        .croquis__note {
          font-size: 13px;
        }
      }

      /* ── Mobile Croquis ────────────────────────── */
      @media (max-width: 640px) {
        .croquis {
          padding: 64px 24px 56px;
        }

        .croquis__inner {
          gap: 28px;
        }

        .croquis__rail {
          gap: 28px;
        }

        .croquis__header {
          gap: 12px;
        }

        .croquis__caption {
          font-size: 11px;
        }

        .croquis__title {
          font-size: 32px;
          line-height: 1.12;
        }

        .croquis__subtitle {
          font-size: 14px;
        }

        .croquis__details {
          gap: 12px;
        }

        .croquis__info {
          font-size: 13px;
          line-height: 1.5;
        }

        .croquis__info--desktop { display: none; }
        .croquis__info--mobile { display: block; }

        .croquis__map-img {
          width: 100%;
        }
      }

      /* ── Galería Sección ───────────────────────── */
      .galeria {
        padding: 88px 60px 80px;
        background: var(--bg-cream);
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 56px;
        border-top: 1px solid rgba(28, 28, 28, 0.15);
      }

      .galeria__header {
        text-align: center;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 18px;
      }

      .galeria__eyebrow {
        font-size: 11px;
        font-weight: 500;
        letter-spacing: 2.5px;
        color: var(--text-secondary);
      }

      .galeria__title {
        font-family: 'Playfair Display', Georgia, serif;
        font-size: 64px;
        line-height: 1.05;
        font-weight: normal;
        font-style: italic;
        color: var(--text-dark);
      }

      .galeria__subtitle {
        font-size: 14px;
        color: var(--text-secondary);
        max-width: 480px;
        line-height: 1.5;
      }

      /* Tabs de Días */
      .tabs {
        display: inline-flex;
        background: #FFFFFF;
        border: 1px solid rgba(28, 28, 28, 0.15);
        border-radius: 999px;
        padding: 6px;
        gap: 8px;
      }

      .tab-btn {
        background: none;
        border: none;
        padding: 10px 24px;
        font-family: 'Inter', sans-serif;
        font-size: 13px;
        font-weight: 600;
        color: var(--text-secondary);
        border-radius: 999px;
        cursor: pointer;
        transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
      }

      .tab-btn:hover {
        color: var(--text-dark);
      }

      .tab-btn.active {
        background: var(--text-dark);
        color: var(--bg-cream);
      }

      /* Contenedor de Collages */
      .collages-container {
        width: 100%;
        max-width: 1200px;
        min-height: 520px;
      }

      .collage-pane {
        display: none;
        grid-template-columns: 1fr 1.2fr 1fr;
        gap: 24px;
        animation: fadeInCollage 0.5s ease-out;
      }

      .collage-pane.active {
        display: grid;
      }

      @keyframes fadeInCollage {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
      }

      .collage-col {
        display: flex;
        flex-direction: column;
        gap: 24px;
      }

      .collage-img-wrapper {
        position: relative;
        border-radius: 0px;
        overflow: hidden;
        background: rgba(28, 28, 28, 0.05);
        transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.4s ease;
      }

      .collage-img-wrapper:hover {
        transform: translateY(-4px);
        box-shadow: 0 16px 32px rgba(28, 28, 28, 0.12);
      }

      .collage-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
        transition: transform 0.6s ease;
      }

      .collage-img-wrapper:hover .collage-img {
        transform: scale(1.03);
      }

      /* Alturas de las imágenes para el collage asimétrico */
      .h-vertical-top { height: 290px; }
      .h-landscape-bottom { height: 186px; }
      .h-hero { height: 500px; }
      .h-landscape-top { height: 210px; }
      .h-vertical-bottom { height: 266px; }

      /* CTA */
      .galeria__cta {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 12px;
      }

      .cta-link-btn {
        display: flex;
        align-items: center;
        gap: 14px;
        background: none;
        border: 1px solid var(--text-dark);
        color: var(--text-dark);
        padding: 16px 36px;
        font-size: 14px;
        font-weight: 600;
        text-decoration: none;
        border-radius: 4px;
        transition: background 0.3s, color 0.3s;
      }

      .cta-link-btn:hover {
        background: var(--text-dark);
        color: var(--bg-cream);
      }

      .cta-link-btn svg {
        transition: transform 0.3s ease;
      }

      .cta-link-btn:hover svg {
        transform: translateX(4px);
      }

      .cta-counter {
        font-size: 11px;
        letter-spacing: 1px;
        color: var(--text-secondary);
        text-transform: uppercase;
        font-weight: 500;
      }

      /* ── Tablet Galería ────────────────────────── */
      @media (max-width: 1024px) {
        .galeria {
          padding: 64px 40px;
          gap: 40px;
        }
        .galeria__title {
          font-size: 48px;
        }
        .collage-pane.active {
          grid-template-columns: 1fr 1fr;
        }
        .collage-col--side-right {
          display: none; /* Ocultar la tercera columna en tablet */
        }
        .h-vertical-top { height: 260px; }
        .h-landscape-bottom { height: 200px; }
        .h-hero { height: 484px; }
      }

      /* ── Mobile Galería ────────────────────────── */
      @media (max-width: 640px) {
        .galeria {
          padding: 48px 20px;
          gap: 32px;
        }
        .galeria__title {
          font-size: 36px;
        }
        .tabs {
          padding: 4px;
          gap: 4px;
          width: 100%;
          justify-content: space-between;
        }
        .tab-btn {
          padding: 8px 12px;
          font-size: 12px;
          flex: 1;
          text-align: center;
        }
        .collages-container {
          min-height: auto;
        }
        .collage-pane.active {
          grid-template-columns: 1fr;
          gap: 16px;
        }
        .collage-col--side-left {
          display: none; /* Ocultar primera columna en móvil */
        }
        .collage-col--hero {
          width: 100%;
        }
        .h-hero {
          height: 320px;
        }
        .cta-link-btn {
          padding: 14px 24px;
          font-size: 13px;
          width: 100%;
          justify-content: center;
        }
      }
    </style>
  </head>
