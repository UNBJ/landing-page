          </div>

          {/* Miércoles */}
          <div class="collage-pane" id="pane-miercoles">
            <div class="collage-col collage-col--side-left">
              <div class="collage-img-wrapper h-vertical-top">
                <img src={photosData.miercoles[0]?.url} alt="Foto Miércoles 1" class="collage-img" loading="lazy" />
              </div>
              <div class="collage-img-wrapper h-landscape-bottom">
                <img src={photosData.miercoles[3]?.url} alt="Foto Miércoles 4" class="collage-img" loading="lazy" />
              </div>
            </div>
            <div class="collage-col collage-col--hero">
              <div class="collage-img-wrapper h-hero">
                <img src={photosData.miercoles[1]?.url} alt="Foto Miércoles 2 (Hero)" class="collage-img" loading="lazy" />
              </div>
            </div>
            <div class="collage-col collage-col--side-right">
              <div class="collage-img-wrapper h-landscape-top">
                <img src={photosData.miercoles[2]?.url} alt="Foto Miércoles 3" class="collage-img" loading="lazy" />
              </div>
              <div class="collage-img-wrapper h-vertical-bottom">
                <img src={photosData.miercoles[4]?.url} alt="Foto Miércoles 5" class="collage-img" loading="lazy" />
